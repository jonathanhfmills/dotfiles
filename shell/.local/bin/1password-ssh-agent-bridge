#!/usr/bin/env bash
# Bridge 1Password Windows SSH agent → WSL Unix socket via npiperelay + socat
WINDOWS_USER=$(cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r\n ')
NPIPERELAY="/mnt/c/Users/$WINDOWS_USER/bin/npiperelay.exe"
SOCKET="$HOME/.1password/agent.sock"
mkdir -p "$HOME/.1password"
rm -f "$SOCKET"
exec socat "UNIX-LISTEN:$SOCKET,fork,mode=600" \
  "EXEC:$NPIPERELAY -ei -s //./pipe/openssh-ssh-agent,nofork"
