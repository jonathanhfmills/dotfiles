#!/usr/bin/env python3
"""Convert OMC skill/agent files to gitagent agent directories."""

import re
import sys
import yaml
from pathlib import Path

SKILLS_DIR = Path.home() / ".agents" / "skills"
SKILLS_OUT_DIR = Path.home() / "gitagent-agents"
AGENTS_DIR = Path.home() / "dotfiles" / "omc-agents"
AGENTS_OUT_DIR = Path.home() / "dotfiles" / "gitagent-agents"

MODEL_MAP = {
    "sonnet": "claude-sonnet-4-6",
    "opus": "claude-opus-4-7",
    "haiku": "claude-haiku-4-5-20251001",
}
DEFAULT_MODEL = "claude-sonnet-4-6"

SOUL_XML_TAGS = {"Role", "Why_This_Matters", "Investigation_Protocol",
                 "Tool_Usage", "Output_Format", "Communication_Style",
                 "Domain_Expertise", "Collaboration_Style"}
RULES_XML_TAGS = {"Constraints", "Success_Criteria", "Must_Always",
                  "Must_Never", "Error_Handling", "Boundaries"}

# Markdown section heading classifiers (for SKILL.md)
SOUL_HEADINGS = {"role", "purpose", "capabilities", "overview", "description",
                 "when to use", "when to activate", "domain expertise",
                 "communication style", "values", "collaboration", "identity"}
RULES_HEADINGS = {"rules", "must", "never", "constraints", "boundaries",
                  "must always", "must never", "output constraints",
                  "interaction boundaries", "hard constraints", "error handling"}


# ── Parsers ──────────────────────────────────────────────────────────────────

def parse_frontmatter(text: str) -> tuple[dict, str]:
    if text.startswith("---"):
        parts = text.split("---", 2)
        fm = yaml.safe_load(parts[1]) or {}
        body = parts[2].strip()
    else:
        fm = {}
        body = text.strip()
    return fm, body


def parse_xml_sections(body: str) -> dict[str, str]:
    """Extract named XML tag content from OMC agent prompt.
    Unwraps outer <Agent_Prompt> first so inner tags are parsed correctly."""
    sections = {}
    # Unwrap outer <Agent_Prompt> wrapper if present
    outer = re.search(r"<Agent_Prompt>(.*?)</Agent_Prompt>", body, re.DOTALL)
    inner = outer.group(1) if outer else body
    pattern = re.compile(r"<(\w+)>(.*?)</\1>", re.DOTALL)
    for m in pattern.finditer(inner):
        tag, content = m.group(1), m.group(2).strip()
        sections[tag] = content
    return sections


def split_md_sections(body: str) -> dict[str, str]:
    sections = {}
    current = "_preamble"
    lines = []
    for line in body.splitlines():
        m = re.match(r"^#{1,3}\s+(.+)", line)
        if m:
            if lines:
                sections[current] = "\n".join(lines).strip()
            current = m.group(1).strip()
            lines = []
        else:
            lines.append(line)
    if lines:
        sections[current] = "\n".join(lines).strip()
    return sections


def classify_md_sections(sections: dict[str, str]) -> tuple[dict, dict]:
    soul, rules = {}, {}
    for heading, content in sections.items():
        key = heading.lower()
        if any(r in key for r in RULES_HEADINGS):
            rules[heading] = content
        elif any(s in key for s in SOUL_HEADINGS):
            soul[heading] = content
        elif key != "_preamble":
            soul[heading] = content
    return soul, rules


# ── Builders ─────────────────────────────────────────────────────────────────

def make_agent_yaml(name: str, description: str, model_key: str,
                    tags: list[str], version: str = "0.1.0",
                    author: str = "omc") -> dict:
    preferred = MODEL_MAP.get(str(model_key).lower(), DEFAULT_MODEL)
    return {
        "spec_version": "0.1.0",
        "name": name,
        "version": version,
        "description": " ".join(description.split()) if description else f"OMC agent: {name}",
        "author": author,
        "license": "MIT",
        "model": {
            "preferred": preferred,
            "fallback": ["claude-haiku-4-5-20251001"],
            "constraints": {"temperature": 0.2, "max_tokens": 8192},
        },
        "runtime": {"max_turns": 30, "timeout": 300},
        "tags": tags or ["omc", name],
    }


def build_soul_from_xml(xml: dict, name: str, description: str) -> str:
    lines = [f"# {name} — Soul\n"]
    for tag in ["Role", "Why_This_Matters", "Investigation_Protocol",
                "Tool_Usage", "Output_Format", "Communication_Style",
                "Domain_Expertise", "Collaboration_Style"]:
        if tag in xml:
            heading = tag.replace("_", " ")
            lines.append(f"## {heading}\n{xml[tag]}\n")
    # Remaining soul tags
    for tag, content in xml.items():
        if tag not in SOUL_XML_TAGS and tag not in RULES_XML_TAGS and tag != "Agent_Prompt":
            lines.append(f"## {tag.replace('_', ' ')}\n{content}\n")
    if len(lines) == 1:
        lines.append(f"## Core Identity\n{description}\n")
    return "\n".join(lines)


def build_rules_from_xml(xml: dict) -> str:
    lines = ["# Rules\n"]
    for tag in ["Constraints", "Success_Criteria", "Must_Always", "Must_Never",
                "Error_Handling", "Boundaries"]:
        if tag in xml:
            lines.append(f"## {tag.replace('_', ' ')}\n{xml[tag]}\n")
    if len(lines) == 1:
        return "# Rules\n\n## Must Always\n- Follow OMC agent conventions.\n"
    return "\n".join(lines)


def build_soul_from_md(soul: dict, name: str, description: str) -> str:
    lines = [f"# {name} — Soul\n"]
    if not soul:
        lines.append(f"## Core Identity\n{description}\n")
    for h, c in soul.items():
        lines.append(f"## {h}\n{c}\n")
    return "\n".join(lines)


def build_rules_from_md(rules: dict) -> str:
    if not rules:
        return "# Rules\n\n## Must Always\n- Follow OMC skill conventions.\n"
    lines = ["# Rules\n"]
    for h, c in rules.items():
        lines.append(f"## {h}\n{c}\n")
    return "\n".join(lines)


def write_agent(out: Path, agent_yaml: dict, soul: str, rules: str) -> None:
    out.mkdir(parents=True, exist_ok=True)
    (out / "agent.yaml").write_text(
        yaml.dump(agent_yaml, default_flow_style=False, allow_unicode=True, sort_keys=False)
    )
    (out / "SOUL.md").write_text(soul)
    (out / "RULES.md").write_text(rules)


# ── Converters ────────────────────────────────────────────────────────────────

def convert_agent(name: str) -> Path:
    """Convert OMC agent .md → gitagent dir in dotfiles."""
    src = AGENTS_DIR / f"{name}.md"
    if not src.exists():
        print(f"✗ Not found: {src}", file=sys.stderr)
        sys.exit(1)

    text = src.read_text()
    fm, body = parse_frontmatter(text)
    xml = parse_xml_sections(body)

    model_key = fm.get("model", "sonnet")
    description = fm.get("description", "")
    agent_yaml = make_agent_yaml(
        name=name,
        description=description,
        model_key=model_key,
        tags=["omc", "agent", name],
        author="omc",
    )

    soul = build_soul_from_xml(xml, name, description)
    rules = build_rules_from_xml(xml)

    out = AGENTS_OUT_DIR / name
    write_agent(out, agent_yaml, soul, rules)
    print(f"✓ agent:{name} → {out}")
    return out


def convert_skill(skill_name: str) -> Path:
    """Convert OMC skill SKILL.md → gitagent dir."""
    skill_path = SKILLS_DIR / skill_name / "SKILL.md"
    if not skill_path.exists():
        print(f"✗ Not found: {skill_path}", file=sys.stderr)
        sys.exit(1)

    fm, body = parse_frontmatter(skill_path.read_text())
    sections = split_md_sections(body)
    soul_parts, rules_parts = classify_md_sections(sections)

    description = fm.get("description", "")
    if isinstance(description, str):
        description = " ".join(description.split())
    meta = fm.get("metadata", {}) or {}
    agent_yaml = make_agent_yaml(
        name=skill_name,
        description=description,
        model_key="sonnet",
        tags=["omc", "skill", skill_name],
        version=meta.get("version", "0.1.0") if isinstance(meta, dict) else "0.1.0",
        author=meta.get("author", "omc") if isinstance(meta, dict) else "omc",
    )

    soul = build_soul_from_md(soul_parts, skill_name, description)
    rules = build_rules_from_md(rules_parts)

    out = SKILLS_OUT_DIR / skill_name
    write_agent(out, agent_yaml, soul, rules)
    print(f"✓ skill:{skill_name} → {out}")
    return out


# ── CLI ───────────────────────────────────────────────────────────────────────

USAGE = f"""omc2gitagent — Convert OMC agents/skills to gitagent format

Usage:
  omc2gitagent agent <name>          Convert one OMC agent
  omc2gitagent agent --all           Convert all OMC agents in {AGENTS_DIR}
  omc2gitagent skill <name>          Convert one OMC skill
  omc2gitagent skill --all           Convert all OMC skills in {SKILLS_DIR}

Output:
  agents → {AGENTS_OUT_DIR}/<name>/
  skills → {SKILLS_OUT_DIR}/<name>/

Run converted agent:
  npx @open-gitagent/gitagent@latest run -d <out-dir> -a claude -p 'prompt'
"""


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)

    mode = args[0]
    rest = args[1:]

    if mode == "agent":
        if not rest:
            print("Error: specify agent name or --all", file=sys.stderr)
            sys.exit(1)
        if rest[0] == "--all":
            agents = [p.stem for p in AGENTS_DIR.glob("*.md")]
            if not agents:
                print(f"No agents found in {AGENTS_DIR}", file=sys.stderr)
                sys.exit(1)
            for a in sorted(agents):
                convert_agent(a)
            print(f"\nDone. {len(agents)} agents → {AGENTS_OUT_DIR}")
        else:
            out = convert_agent(rest[0])
            print(f"\nRun: npx @open-gitagent/gitagent@latest run -d {out} -a claude -p 'prompt'")

    elif mode == "skill":
        if not rest:
            print("Error: specify skill name or --all", file=sys.stderr)
            sys.exit(1)
        if rest[0] == "--all":
            skills = [d.name for d in SKILLS_DIR.iterdir() if (d / "SKILL.md").exists()]
            if not skills:
                print(f"No skills found in {SKILLS_DIR}", file=sys.stderr)
                sys.exit(1)
            for s in sorted(skills):
                convert_skill(s)
            print(f"\nDone. {len(skills)} skills → {SKILLS_OUT_DIR}")
        else:
            out = convert_skill(rest[0])
            print(f"\nRun: npx @open-gitagent/gitagent@latest run -d {out} -a claude -p 'prompt'")

    else:
        print(f"Unknown mode '{mode}'. Use: agent | skill", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
